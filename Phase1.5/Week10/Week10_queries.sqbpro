 value="300"/><column index="6" value="156"/><column index="7" value="54"/><column index="8" value="117"/><column index="9" value="85"/><column index="10" value="156"/><column index="11" value="148"/><column index="12" value="234"/><column index="13" value="88"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Track" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="51"/><column index="2" value="300"/><column index="3" value="58"/><column index="4" value="83"/><column index="5" value="56"/><column index="6" value="300"/><column index="7" value="76"/><column index="8" value="70"/><column index="9" value="59"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- Query 1: Return all columns and rows from Artist

SELECT *
from Artist;

--Query 2: Return only the FirstName, LastName, and Country columns from the Customer table

SELECT FirstName, LastName, Country
FROM Customer;

-- Query 3: Return all customers from the Customer table whose Country is 'Germany'

SELECT *
FROM Customer
Where Country= 'Germany';

-- Query 4: Return all tracks from the Track table where Milliseconds is greater than 300000 (longer than 5 minutes), sorted by length descending

SELECT *
FROM Track
WHERE Milliseconds &gt; 300000
ORDER BY Milliseconds DESC;

-- Query 5: Return the Name and UnitPrice of the 10 most expensive tracks. Hint: ORDER BY combined with LIMIT

SELECT Name, UnitPrice
FROM Track
ORDER BY UnitPrice DESC
LIMIT 10</sql><current_tab id="0"/></tab_sql></sqlb_project>
